                </div>

            </div>
        </div>
    </section>

    <!-- Skills Section -->
    <section id="habilidades" class="py-32 px-6 relative z-10">
        <div class="max-w-7xl mx-auto relative z-10">
            <div class="flex flex-col md:flex-row justify-between items-end mb-20 gap-8">
                <div class="max-w-2xl">
                    <h3 class="text-6xl md:text-7xl font-medium text-white uppercase tracking-tighter relative z-10 leading-none">
                        <i data-lucide="sparkles" class="w-10 h-10 text-accent inline-block mr-4 align-middle"></i>MIS <span class="text-accent">HABILIDADES</span>
                    </h3>
                </div>
                <p class="text-white/40 text-lg max-w-sm pb-2 border-l-2 border-accent pl-6 font-normal">
                    Combinando estética y funcionalidad para crear productos digitales memorables.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                <!-- Skill 1 -->
                <div class="skill-card p-8 rounded-[32px] space-y-6">
                    <div class="w-14 h-14 bg-accent/10 rounded-2xl flex items-center justify-center">
                        <i data-lucide="layout" class="text-accent w-8 h-8"></i>
                    </div>
                    <div class="space-y-4">
                        <h4 class="text-xl font-medium text-white uppercase tracking-tight">Design Thinking</h4>
                        <p class="text-sm text-white/50 leading-relaxed font-normal">Definición de producto, propuesta de valor y alineación de objetivos.</p>
                        <ul class="space-y-2 pt-4 border-t border-white/5">
                            <li class="flex items-center gap-2 text-[13px] text-white/40 font-normal"><span class="w-1 h-1 rounded-full bg-accent"></span> Problem Framing</li>
                            <li class="flex items-center gap-2 text-[13px] text-white/40 font-normal"><span class="w-1 h-1 rounded-full bg-accent"></span> Information Architecture</li>
                            <li class="flex items-center gap-2 text-[13px] text-white/40 font-normal"><span class="w-1 h-1 rounded-full bg-accent"></span> User Flow Mapping</li>
                            <li class="flex items-center gap-2 text-[13px] text-white/40 font-normal"><span class="w-1 h-1 rounded-full bg-accent"></span> Feature Prioritization</li>
                            <li class="flex items-center gap-2 text-[13px] text-white/40 font-normal"><span class="w-1 h-1 rounded-full bg-accent"></span> Conversion-Oriented Decisions</li>
                        </ul>
                    </div>
                </div>
                <!-- Skill 2 -->
                <div class="skill-card p-8 rounded-[32px] space-y-6">
                    <div class="w-14 h-14 bg-accent/10 rounded-2xl flex items-center justify-center">
                        <i data-lucide="component" class="text-accent w-8 h-8"></i>
                    </div>
                    <div class="space-y-4">
                        <h4 class="text-xl font-medium text-white uppercase tracking-tight">Visual & Interface Systems</h4>
                        <p class="text-sm text-white/50 leading-relaxed font-normal">Creación de interfaces intuitivas y estéticas con enfoque en la usabilidad.</p>
                        <ul class="space-y-2 pt-4 border-t border-white/5">
                            <li class="flex items-center gap-2 text-[13px] text-white/40 font-normal"><span class="w-1 h-1 rounded-full bg-accent"></span> High-Fidelity UI Design</li>
                            <li class="flex items-center gap-2 text-[13px] text-white/40 font-normal"><span class="w-1 h-1 rounded-full bg-accent"></span> Layout & Grid Systems</li>
                            <li class="flex items-center gap-2 text-[13px] text-white/40 font-normal"><span class="w-1 h-1 rounded-full bg-accent"></span> Typography Systems</li>
                            <li class="flex items-center gap-2 text-[13px] text-white/40 font-normal"><span class="w-1 h-1 rounded-full bg-accent"></span> Color Systems & Visual Hierarchy</li>
                            <li class="flex items-center gap-2 text-[13px] text-white/40 font-normal"><span class="w-1 h-1 rounded-full bg-accent"></span> Component-Based Design</li>
                            <li class="flex items-center gap-2 text-[13px] text-white/40 font-normal"><span class="w-1 h-1 rounded-full bg-accent"></span> Design Systems Thinking</li>
                            <li class="flex items-center gap-2 text-[13px] text-white/40 font-normal"><span class="w-1 h-1 rounded-full bg-accent"></span> Brand Translation to Interface</li>
                        </ul>
                    </div>
                </div>
                <!-- Skill 3 -->
                <div class="skill-card p-8 rounded-[32px] space-y-6">
                    <div class="w-14 h-14 bg-accent/10 rounded-2xl flex items-center justify-center">
                        <i data-lucide="map" class="text-accent w-8 h-8"></i>
                    </div>
                    <div class="space-y-4">
                        <h4 class="text-xl font-medium text-white uppercase tracking-tight">Product & Structure</h4>
                        <p class="text-sm text-white/50 leading-relaxed font-normal">Análisis de comportamiento y necesidades de usuarios reales.</p>
                        <ul class="space-y-2 pt-4 border-t border-white/5">
                            <li class="flex items-center gap-2 text-[13px] text-white/40 font-normal"><span class="w-1 h-1 rounded-full bg-accent"></span> Information Architecture</li>
                            <li class="flex items-center gap-2 text-[13px] text-white/40 font-normal"><span class="w-1 h-1 rounded-full bg-accent"></span> User Flow Mapping</li>
                            <li class="flex items-center gap-2 text-[13px] text-white/40 font-normal"><span class="w-1 h-1 rounded-full bg-accent"></span> Feature Prioritization</li>
                            <li class="flex items-center gap-2 text-[13px] text-white/40 font-normal"><span class="w-1 h-1 rounded-full bg-accent"></span> Conversion-Oriented Decisions</li>
                            <li class="flex items-center gap-2 text-[13px] text-white/40 font-normal"><span class="w-1 h-1 rounded-full bg-accent"></span> Dashboard Structuring</li>
                            <li class="flex items-center gap-2 text-[13px] text-white/40 font-normal"><span class="w-1 h-1 rounded-full bg-accent"></span> Content Hierarchy</li>
                            <li class="flex items-center gap-2 text-[13px] text-white/40 font-normal"><span class="w-1 h-1 rounded-full bg-accent"></span> Iterative Design Process</li>
                        </ul>
                    </div>
                </div>
                <!-- Skill 4 -->
                <div class="skill-card p-8 rounded-[32px] space-y-6">
                    <div class="w-14 h-14 bg-accent/10 rounded-2xl flex items-center justify-center">
                        <i data-lucide="play-circle" class="text-accent w-8 h-8"></i>
                    </div>
                    <div class="space-y-4">
                        <h4 class="text-xl font-medium text-white uppercase tracking-tight">Tools & Execution</h4>
                        <p class="text-sm text-white/50 leading-relaxed font-normal">Construcción de prototipos interactivos de alta fidelidad.</p>
                        <ul class="space-y-2 pt-4 border-t border-white/5">
                            <li class="flex items-center gap-2 text-[13px] text-white/40 font-normal"><span class="w-1 h-1 rounded-full bg-accent"></span> Figma (Auto Layout, Components, Variants)</li>
                            <li class="flex items-center gap-2 text-[13px] text-white/40 font-normal"><span class="w-1 h-1 rounded-full bg-accent"></span> Responsive Design</li>
                            <li class="flex items-center gap-2 text-[13px] text-white/40 font-normal"><span class="w-1 h-1 rounded-full bg-accent"></span> Interactive Prototyping</li>
                            <li class="flex items-center gap-2 text-[13px] text-white/40 font-normal"><span class="w-1 h-1 rounded-full bg-accent"></span> Design Handoff to Developers</li>
                            <li class="flex items-center gap-2 text-[13px] text-white/40 font-normal"><span class="w-1 h-1 rounded-full bg-accent"></span> UI Documentation</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contacto" class="py-32 px-6 bg-[#0a0c16]">
        <div class="max-w-7xl mx-auto">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-20">
                <div class="space-y-12">
                    <h2 class="text-7xl md:text-8xl font-medium text-white uppercase tracking-tighter leading-none">
                        <i data-lucide="send" class="w-10 h-10 text-accent inline-block mr-4 align-middle"></i>CONTACTO
                    </h2>
                    <p class="text-xl text-white/60 max-w-md font-normal leading-relaxed">
                        Estoy disponible para nuevos desafíos y colaboraciones. Hablemos sobre cómo puedo ayudarte a potenciar tu producto.
                    </p>
                    
                    <div class="flex items-center gap-6 pt-8">
                        <a href="#" class="w-14 h-14 rounded-full border border-white/10 flex items-center justify-center hover:bg-accent hover:border-accent transition-all duration-300">
                            <i data-lucide="mail" class="w-6 h-6"></i>
                        </a>
                        <a href="#" class="w-14 h-14 rounded-full border border-white/10 flex items-center justify-center hover:bg-accent hover:border-accent transition-all duration-300">
                            <i data-lucide="linkedin" class="w-6 h-6"></i>
                        </a>
                        <a href="#" class="w-14 h-14 rounded-full border border-white/10 flex items-center justify-center hover:bg-accent hover:border-accent transition-all duration-300">
                            <i data-lucide="instagram" class="w-6 h-6"></i>
                        </a>
                        <a href="#" class="w-14 h-14 rounded-full border border-white/10 flex items-center justify-center hover:bg-accent hover:border-accent transition-all duration-300">
                            <i data-lucide="dribbble" class="w-6 h-6"></i>
                        </a>
                    </div>
                </div>

                <form class="space-y-8 bg-white/5 p-10 md:p-12 rounded-[40px] border border-white/5">
                    <div class="space-y-2">
                        <label for="name" class="text-xs font-medium uppercase tracking-widest text-white/40">Nombre completo</label>
                        <input type="text" id="name" name="name" required placeholder="Tu nombre" class="w-full bg-transparent border-b border-white/10 py-4 focus:border-accent outline-none transition-colors text-lg font-normal">
                    </div>
                    <div class="space-y-2">
                        <label for="email" class="text-xs font-medium uppercase tracking-widest text-white/40">Email</label>
                        <input type="email" id="email" name="email" required placeholder="tu@email.com" class="w-full bg-transparent border-b border-white/10 py-4 focus:border-accent outline-none transition-colors text-lg font-normal">
                    </div>
                    <div class="space-y-2">
                        <label for="message" class="text-xs font-medium uppercase tracking-widest text-white/40">Mensaje</label>
                        <textarea id="message" name="message" required rows="4" placeholder="Cuéntame sobre tu proyecto" class="w-full bg-transparent border-b border-white/10 py-4 focus:border-accent outline-none transition-colors text-lg font-normal resize-none"></textarea>
                    </div>
                    <button type="submit" class="bg-accent text-white px-12 py-5 rounded-full text-sm font-medium hover:scale-105 transition shadow-lg w-full md:w-fit uppercase tracking-wider">
                        Enviar Mensaje
                    </button>
                </form>
            </div>
        </div>
    </section>

    <script>
        // Navbar Scroll Effect
        const navbar = document.getElementById('navbar');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 100) {
                navbar.classList.add('nav-scrolled');
            } else {
                navbar.classList.remove('nav-scrolled');
            }
        });

        document.addEventListener('DOMContentLoaded', () => {
            lucide.createIcons();

            function initCarousel(containerId, nextBtnId) {
                const container = document.getElementById(containerId);
                if (!container) return;
                const nextBtn = document.getElementById(nextBtnId);
                const items = container.querySelectorAll('.carousel-item');
                let currentIndex = 0;

                function showNext() {
                    items[currentIndex].classList.remove('active');
                    currentIndex = (currentIndex + 1) % items.length;
                    items[currentIndex].classList.add('active');
                }
                nextBtn.addEventListener('click', showNext);
            }

            function initExpand(toggleId, collapseId, detailsId) {
                const toggleBtn = document.getElementById(toggleId);
                const collapseBtn = document.getElementById(collapseId);
                const details = document.getElementById(detailsId);
                const btnText = toggleBtn.querySelector('.btn-text');

                function toggleDetails() {
                    const isOpen = details.classList.contains('open');
                    details.classList.toggle('open');
                    toggleBtn.classList.toggle('open');
                    btnText.textContent = isOpen ? 'Ver detalles' : 'Ocultar detalles';
                }

                toggleBtn.addEventListener('click', toggleDetails);
                collapseBtn.addEventListener('click', toggleDetails);
            }

            initCarousel('agualuz-carousel', 'next-agualuz');
            initExpand('toggle-agualuz', 'collapse-agualuz', 'agualuz-details');
            initCarousel('lemonth-carousel', 'next-lemonth');
            initExpand('toggle-lemonth', 'collapse-lemonth', 'lemonth-details');
            initCarousel('fujita-carousel', 'next-fujita');
            initExpand('toggle-fujita', 'collapse-fujita', 'fujita-details');
        });
    </script>
</body>
</html>